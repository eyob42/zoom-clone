<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zoom Clone</title>
    <script>
        const ROOM_ID = "<%= roomId %>";
    </script>
    <script>
    // Make PeerJS work with HTTPS
    const peerConfig = {
        path: '/peerjs',
        host: window.location.hostname,
        port: window.location.protocol === 'https:' ? 443 : 3000,
        secure: window.location.protocol === 'https:'
    };
    </script>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="style.css">
    
    <!-- jQuery (must come before Bootstrap JS) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Socket.io -->
    <script src="/socket.io/socket.io.js"></script>
    <!-- PeerJS -->
    <script src="https://unpkg.com/peerjs@1.4.7/dist/peerjs.min.js"></script>
</head>
<body>
    <div class="container-fluid p-0 vh-100">
        <div class="row g-0 h-100">
            <!-- Main Video Area (9 columns) -->
            <div class="col-12 col-lg-9 main-video-area">
                <div class="video-grid" id="video-grid"></div>
                
                <!-- Controls Bar -->
                <div class="controls-bar">
                    <div class="controls-left">
                        <button class="control-btn" id="muteBtn">
                            <i class="fa-solid fa-microphone"></i>
                            <span>Mute</span>
                        </button>
                        <button class="control-btn" id="videoBtn">
                            <i class="fa-solid fa-video"></i>
                            <span>Stop Video</span>
                        </button>
                        <button class="control-btn" id="securityBtn">
                            <i class="fa-solid fa-shield"></i>
                            <span>Security</span>
                        </button>
                        <button class="control-btn" id="participantsBtn" data-bs-toggle="offcanvas" data-bs-target="#participantsPanel">
                            <i class="fa-solid fa-users"></i>
                            <span>Participants</span>
                        </button>
                        <button class="control-btn" id="chatBtn" data-bs-toggle="offcanvas" data-bs-target="#chatPanel">
                            <i class="fa-solid fa-comment"></i>
                            <span>Chat</span>
                        </button>
                    </div>
                    
                    <div class="controls-center">
                        <button class="control-btn leave-btn" id="leaveBtn">
                            <i class="fa-solid fa-phone-slash"></i>
                            <span>Leave Meeting</span>
                        </button>
                    </div>
                    
                    <div class="controls-right">
                        <div class="message-input">
                            <input type="text" placeholder="Type message here" id="quickMessage">
                            <button class="send-quick-btn" id="sendQuickMessage">
                                <i class="fa-solid fa-paper-plane"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Chat Sidebar (3 columns, hidden on mobile) -->
            <div class="col-12 col-lg-3 chat-sidebar d-none d-lg-block" id="chatSidebar">
                <div class="chat-container">
                    <div class="chat-header">
                        <h5>Chat <span class="badge bg-primary" id="unreadBadge" style="display: none;">0</span></h5>
                        <button class="btn-close btn-close-white" id="closeChat"></button>
                    </div>
                    
                    <div class="chat-messages" id="chatMessages">
                        <!-- Messages will appear here -->
                    </div>
                    
                    <div class="chat-input-container">
                        <input type="text" class="form-control" id="chatInput" placeholder="Type your message...">
                        <button class="btn btn-primary" id="sendMessage">
                            <i class="fa-solid fa-paper-plane"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Participants Offcanvas (Bootstrap) -->
            <div class="offcanvas offcanvas-end bg-dark text-white" tabindex="-1" id="participantsPanel" aria-labelledby="participantsPanelLabel">
                <div class="offcanvas-header">
                    <h5 class="offcanvas-title" id="participantsPanelLabel">Participants</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
                </div>
                <div class="offcanvas-body">
                    <ul class="list-group list-group-flush bg-dark" id="participantsList">
                        <!-- Participants will be added here -->
                    </ul>
                </div>
            </div>

            <!-- Chat Offcanvas (for mobile) -->
            <div class="offcanvas offcanvas-end bg-dark text-white" tabindex="-1" id="chatPanel" aria-labelledby="chatPanelLabel">
                <div class="offcanvas-header">
                    <h5 class="offcanvas-title" id="chatPanelLabel">Chat</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
                </div>
                <div class="offcanvas-body">
                    <div class="chat-messages" id="mobileChatMessages"></div>
                    <div class="chat-input-container mt-3">
                        <input type="text" class="form-control" id="mobileChatInput" placeholder="Type your message...">
                        <button class="btn btn-primary" id="mobileSendMessage">
                            <i class="fa-solid fa-paper-plane"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast notification container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="liveToast" class="toast bg-dark text-white" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header bg-primary text-white">
                <i class="fa-solid fa-comment me-2"></i>
                <strong class="me-auto">New Message</strong>
                <small>just now</small>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body" id="toastBody">
                <!-- Message preview -->
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>